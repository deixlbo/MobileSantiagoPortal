{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "npm run typecheck && npm run build -w @workspace/api-server && npm run build -w @workspace/mockup-sandbox",
    "build:full": "npm run typecheck && npm run build -w @workspace/api-server && npm run build -w @workspace/barangay-mobile && npm run build -w @workspace/mockup-sandbox",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs",
    "dev": "npm run dev -w @workspace/mockup-sandbox"
  },
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@replit/vite-plugin-cartographer": "^0.5.5",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "fast-glob": "^3.3.3",
    "next": "^16.2.4",
    "openai": "^6.34.0",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "react": "^19.2.5",
    "vite": "^8.0.9"
  }
}
